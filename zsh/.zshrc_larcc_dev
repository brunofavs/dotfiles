#----------------------
#      Plugins
#---------------------
# Enabling fzf keybinds
source /usr/share/doc/fzf/examples/key-bindings.zsh

# Different name in Ubuntu
setup_fzf fdfind
#----------------------
#      Alias
#---------------------
# Overriding cat because in apt the package has another name
alias cat="batcat"

#----------------------
#     ROS2 Jazzy
#---------------------

source /opt/ros/jazzy/setup.zsh

# Number between 0 and 101
#https://docs.ros.org/en/jazzy/Concepts/Intermediate/About-Domain-ID.html#choosing-a-domain-id-short-version
export ROS_DOMAIN_ID=0
export ROS_AUTOMATIC_DISCOVERY_RANGE=LOCALHOST
